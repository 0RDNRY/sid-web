---
const base = import.meta.env.BASE_URL;
const current = Astro.url.pathname;

const link = (path = "") => `${base}${path}`.replace(/\/{2,}/g, "/");
---

<nav>

<a href={link()} class="logo">
<strong>sid</strong>
</a>

<div class="links">

<a
href={link("about/")}
class={current.includes("/about") ? "active" : ""}
>
about
</a>

<a
href={link("tech/")}
class={current.includes("/tech") ? "active" : ""}
>
tech
</a>

<a
href={link("creative/")}
class={current.includes("/creative") ? "active" : ""}
>
creative
</a>

<a
href={link("contact/")}
class={current.includes("/contact") ? "active" : ""}
>
contact
</a>

</div>

</nav>
